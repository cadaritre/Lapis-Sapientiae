<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LapisGui.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="720"
        x:Class="LapisGui.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Lapis Sapientiae"
        Width="1200" Height="720"
        MinWidth="900" MinHeight="520"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="40"
        SystemDecorations="Full">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- Custom Title Bar -->
        <Border DockPanel.Dock="Top" Height="40" Background="#0d0f14"
                PointerPressed="OnTitleBarPointerPressed">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- App identity -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10"
                            Margin="16,0,0,0" VerticalAlignment="Center">
                    <Border Width="20" Height="20" CornerRadius="4"
                            Background="#6c8aff" Opacity="0.9">
                        <TextBlock Text="&#x25C6;" FontSize="12"
                                   Foreground="#ffffff"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Lapis Sapientiae" FontSize="13" FontWeight="SemiBold"
                               Foreground="#8b8fa3" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Drag region (transparent, fills center) -->
                <Border Grid.Column="1" Background="Transparent"/>

                <!-- Status indicators + window controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12"
                            Margin="0,0,0,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse Classes="status-dot"
                                 Fill="{Binding StatusColor}"/>
                        <TextBlock Text="{Binding ConnectionStatus}"
                                   FontSize="11" Foreground="#6b7084"/>
                    </StackPanel>
                    <Border Background="#1a1d27" CornerRadius="6" Padding="10,4"
                            BorderBrush="#2a2d38" BorderThickness="1"
                            IsVisible="{Binding IsSimulationMode}">
                        <TextBlock Text="SIM" FontSize="10" FontWeight="Bold"
                                   Foreground="#f0a050"/>
                    </Border>

                    <Border Width="1" Height="16" Background="#2a2d38" Margin="2,0"/>
                    <Button Classes="window-btn" Command="{Binding ToggleSettingsCommand}"
                            ToolTip.Tip="Settings">
                        <TextBlock Text="&#x2699;" FontSize="14" Foreground="#6b7084"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>

                    <Border Width="1" Height="16" Background="#2a2d38" Margin="2,0"/>

                    <Button Classes="window-btn" Click="OnMinimizeClick"
                            ToolTip.Tip="Minimize">
                        <TextBlock Text="&#x2015;" FontSize="10" Foreground="#6b7084"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>

                    <Button Classes="window-btn window-close" Click="OnCloseClick"
                            ToolTip.Tip="Close">
                        <TextBlock Text="&#x2715;" FontSize="11" Foreground="#6b7084"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top" Height="1" Background="#1a1d27"/>

        <!-- Main Content: Sidebar + Chat + Right Panel -->
        <Grid ColumnDefinitions="220,1,*,1,340">

            <!-- ── Left Sidebar: Conversations ── -->
            <DockPanel Grid.Column="0" Background="#0a0c10">

                <!-- New conversation button -->
                <Button DockPanel.Dock="Top" Margin="12,12,12,8"
                        Classes="primary" HorizontalAlignment="Stretch"
                        Command="{Binding NewConversationCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Center">
                        <TextBlock Text="+" FontSize="14" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="New Project" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Section label -->
                <TextBlock DockPanel.Dock="Top" Text="PROJECTS"
                           FontSize="10" FontWeight="Bold" Foreground="#3d4052"
                           Margin="16,4,0,8"
                           LetterSpacing="1.5"/>

                <!-- Conversation list -->
                <ListBox Margin="8,0,8,12"
                         ItemsSource="{Binding Conversations}"
                         SelectedItem="{Binding SelectedConversation}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="CornerRadius" Value="8"/>
                            <Setter Property="Foreground" Value="#8b8fa3"/>
                            <Setter Property="FontSize" Value="12"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="#1a1d27"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#12141a"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ConversationItem">
                            <DockPanel>
                                <Border DockPanel.Dock="Left" Width="6" Height="6"
                                        CornerRadius="3" Margin="0,0,10,0"
                                        Background="{Binding StatusColor}"
                                        VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="#c8cad3"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Subtitle}"
                                               FontSize="10" Foreground="#3d4052"
                                               Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Divider -->
            <Border Grid.Column="1" Background="#1a1d27"/>

            <!-- ── Center: Chat Panel + Settings Overlay ── -->
            <Grid Grid.Column="2">

                <!-- Chat Panel -->
                <DockPanel Margin="16,12,8,16"
                           IsVisible="{Binding !IsSettingsOpen}">

                    <TextBlock DockPanel.Dock="Top" Classes="section-header"
                               Text="CHAT"/>

                    <!-- Input area -->
                    <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto"
                          Margin="0,10,0,0">
                        <TextBox Grid.Column="0"
                                 Text="{Binding UserInput}"
                                 Watermark="Describe what you want the agent to do..."
                                 KeyDown="OnInputKeyDown"/>
                        <Button Grid.Column="1" Classes="primary"
                                Content="Send" Margin="8,0,0,0"
                                Command="{Binding SendMessageCommand}"/>
                    </Grid>

                    <!-- Messages -->
                    <Border Classes="card" Padding="14">
                        <ListBox Classes="chat"
                                 ItemsSource="{Binding ChatMessages}"
                                 AutoScrollToSelectedItem="True">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ChatMessage">
                                    <StackPanel Margin="0,4">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Role}"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="{Binding RoleColor}"/>
                                            <TextBlock Text="{Binding Timestamp}"
                                                       FontSize="10" Foreground="#3d4052"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Content}"
                                                   TextWrapping="Wrap"
                                                   Foreground="#c8cad3" FontSize="13"
                                                   Margin="0,3,0,0"
                                                   LineHeight="20"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </DockPanel>

                <!-- Settings Panel (overlay) -->
                <Border Margin="16,12,8,16" Classes="card" Padding="0"
                        IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsSettingsOpen}"
                        DataContext="{Binding Settings}">
                    <DockPanel>

                        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto"
                              Margin="20,16,20,0">
                            <TextBlock Text="SETTINGS" Classes="section-header"
                                       FontSize="12" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Classes="window-btn"
                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ToggleSettingsCommand}"
                                    ToolTip.Tip="Close settings">
                                <TextBlock Text="&#x2715;" FontSize="11" Foreground="#6b7084"/>
                            </Button>
                        </Grid>

                        <Button DockPanel.Dock="Bottom" Classes="primary"
                                Content="Save" Margin="20,10,20,16"
                                HorizontalAlignment="Left"
                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SaveSettingsCommand}"/>

                        <ScrollViewer Margin="0,8,0,0" Padding="20,0">
                            <StackPanel Spacing="20">

                                <!-- Vision Model -->
                                <Border Background="#0d0f14" CornerRadius="10"
                                        Padding="16" BorderBrush="#1e2029"
                                        BorderThickness="1">
                                    <StackPanel Spacing="12">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="&#x1F441;" FontSize="14"/>
                                            <TextBlock Text="VISION MODEL (LOCAL)"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="#6c8aff"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Endpoint" FontSize="11"
                                                       Foreground="#6b7084"/>
                                            <TextBox Text="{Binding VisionEndpoint}"
                                                     Watermark="http://localhost:11434"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Model" FontSize="11"
                                                       Foreground="#6b7084"/>
                                            <TextBox Text="{Binding VisionModel}"
                                                     Watermark="llava:latest"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Reasoning Model -->
                                <Border Background="#0d0f14" CornerRadius="10"
                                        Padding="16" BorderBrush="#1e2029"
                                        BorderThickness="1">
                                    <StackPanel Spacing="12">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="&#x1F9E0;" FontSize="14"/>
                                            <TextBlock Text="REASONING MODEL (CLOUD)"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="#50c878"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Provider" FontSize="11"
                                                       Foreground="#6b7084"/>
                                            <ComboBox ItemsSource="{Binding Providers}"
                                                      SelectedItem="{Binding SelectedProvider}"
                                                      HorizontalAlignment="Stretch"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="API Key" FontSize="11"
                                                       Foreground="#6b7084"/>
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding ApiKey}"
                                                         Watermark="sk-..."
                                                         RevealPassword="{Binding !IsApiKeyVisible}"
                                                         PasswordChar="*"/>
                                                <Button Grid.Column="1" Classes="window-btn"
                                                        Margin="4,0,0,0"
                                                        Command="{Binding ToggleApiKeyVisibilityCommand}"
                                                        ToolTip.Tip="Toggle visibility">
                                                    <TextBlock Text="&#x1F441;" FontSize="12"
                                                               Foreground="#6b7084"/>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Model" FontSize="11"
                                                       Foreground="#6b7084"/>
                                            <TextBox Text="{Binding ReasoningModel}"
                                                     Watermark="claude-sonnet-4-20250514"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Divider -->
            <Border Grid.Column="3" Background="#1a1d27"/>

            <!-- ── Right: Screenshot + Logs ── -->
            <DockPanel Grid.Column="4" Margin="8,12,16,16">

                <!-- Screenshot card -->
                <Border DockPanel.Dock="Top" Classes="card" Height="260"
                        Margin="0,0,0,10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Classes="section-header"
                                   Text="SCREENSHOT" Margin="14,12,14,8"/>
                        <Border Background="#0a0c10" Margin="10,0,10,10"
                                CornerRadius="8">
                            <TextBlock Text="No capture"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#2a2d38" FontSize="12"
                                       FontStyle="Italic"/>
                        </Border>
                    </DockPanel>
                </Border>

                <!-- Logs card -->
                <Border Classes="card" Padding="0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Classes="section-header"
                                   Text="LOGS" Margin="14,12,14,8"/>
                        <ListBox Classes="logs" Margin="14,0,14,10"
                                 ItemsSource="{Binding LogEntries}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:LogEntry">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Level}"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="{Binding LevelColor}"
                                                   Width="32"/>
                                        <TextBlock Text="{Binding Message}"
                                                   TextWrapping="Wrap"
                                                   Foreground="#6b7084" FontSize="11"
                                                   FontFamily="{StaticResource MonoFont}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
